parent = "C:/Scans_Daniella";  // optional start location

petdir = getDirectory("Select PET folder (sub-..._totalbody...)");
list = getFileList(petdir);
subject = "";

// STEP 1: rename PET files
for (i = 0; i < list.length; i++) {

    name = list[i];
    newname = name;

    // Remove pet_ at start
    if (startsWith(newname, "pet_"))
        newname = substring(newname, 4);

    // If filename contains _BRAIN
    if (indexOf(newname, "_BRAIN") != -1) {
        newname = replace(newname, "_BRAIN", "");
        newname = replace(newname, "totalbody", "brain");
    }

    // extract subject ID
    if (subject == "" && indexOf(newname, "sub-TAP") != -1) {
        start = indexOf(newname, "sub-TAP");
        subject = substring(newname, start, start+13);
    }

    if (newname != name)
        File.rename(petdir + name, petdir + newname);
}

// STEP 2: find mr2pet_hires folder automatically
root = substring(petdir, 0, indexOf(petdir, "pet"));
mrdir = root + "anat/processed/mr2pet_hires/";

// STEP 3: rename MRI2PET files
if (File.exists(mrdir)) {

    if (File.exists(mrdir + "MRI2PET.nii"))
        File.rename(mrdir + "MRI2PET.nii", mrdir + subject + "_mr2pet_hires.nii");

    if (File.exists(mrdir + "MRI2PET.img"))
        File.rename(mrdir + "MRI2PET.img", mrdir + subject + "_mr2pet_hires.img");

    if (File.exists(mrdir + "MRI2PET.hdr"))
        File.rename(mrdir + "MRI2PET.hdr", mrdir + subject + "_mr2pet_hires.hdr");

    print("MRI2PET files renamed for " + subject);

} else {
    print("mr2pet_hires folder not found.");
}
